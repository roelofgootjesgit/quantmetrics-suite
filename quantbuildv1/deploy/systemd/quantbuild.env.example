# Install as /etc/quantbuild/quantbuild.env (mode 600). Do not commit real values.
# Full variable list + philosophy: docs/CREDENTIALS_AND_ENVIRONMENT.md
# Primaire VPS-stack: cTrader + QuantBridge (CTRADER_* + QUANTBRIDGE_SRC_PATH).
# OANDA_* alleen als je een config zonder cTrader gebruikt.

CTRADER_ACCOUNT_ID=
CTRADER_ACCESS_TOKEN=
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
QUANTBRIDGE_SRC_PATH=/opt/quantbuild/quantbridgev1/src

OANDA_ACCOUNT_ID=
OANDA_TOKEN=

NEWSAPI_KEY=
FINNHUB_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_INSTANCE_LABEL=

# Optional: QuantLog nightly report (scripts/vps/quantlog_nightly.sh)
# QUANTLOG_REPO_PATH=/opt/quantbuild/quantlogv1
# QUANTBUILD_POST_RUN_CONFIG=configs/ctrader_quantbridge_openapi.yaml
