# VPS / Linux — QuantOS orchestrator: kopieer naar .env in deze map:
#   cd /root/dev/quant/quantmetrics_os/orchestrator
#   cp config.vps.example.env .env
# Pas paden aan als je repos ergens anders staan.
#
# Als `quantmetrics check` nog steeds korte namen toont (alleen quantbuild):
#   grep ^QUANT .env   → moet /root/dev/quant/... zijn
#   unset QUANTBUILD_ROOT QUANTBRIDGE_ROOT QUANTLOG_ROOT QUANTLOG_EVENTS_ROOT
#   (oude shells exporteerden soms relatieve paden; orchestrator/.env heeft nu voorrang)
#
# Altijd absolute paden: dan werkt check/build/notify overal hetzelfde,
# ongeacht vanuit welke directory je python quantmetrics.py draait.

QUANTBUILD_ROOT=/root/dev/quant/quantbuild
QUANTBRIDGE_ROOT=/root/dev/quant/quantbridge
QUANTLOG_ROOT=/root/dev/quant/quantlog

# quantmetrics_os/orchestrator/quantmetrics.py → subcommands ``backtest --analyze`` en ``analyze``
# (QuantLog JSONL → tekstrapport onder quantanalytics/output_rapport/).
QUANTANALYTICS_ROOT=/root/dev/quant/quantanalytics
# Eén venv (QuantBuild): pip install -e "$QUANTANALYTICS_ROOT"

# Leeg laten = standaard <QUANTBUILD_ROOT>/data/quantlog_events.
# Deze regel overschrijft oude shell-exports (bijv. QUANTLOG_EVENTS_ROOT=quantlog_events).
QUANTLOG_EVENTS_ROOT=

# --- Python / venv (zelfde contract als QuantBuild docs/VPS_MULTI_MODULE_DEPLOYMENT.md) ---
# Er is precies ÉÉN productie-venv: in quantbuild/.venv (requirements.txt daar).
# QuantBridge en QuantLog gebruiken geen eigen .venv op productie; de orchestrator
# moet daarom de interpreter van QuantBuild gebruiken — nooit blote python3.
# Eerste keer venv: cd $QUANTBUILD_ROOT && python3.10 -m venv .venv && source .venv/bin/activate
#   && pip install -r requirements.txt
# (Zie ook quantbuild/scripts/vps/bootstrap_vps.sh en docs/VPS_DEPLOYMENT_RUNBOOK.md.)
PYTHON=/root/dev/quant/quantbuild/.venv/bin/python

# QuantBuild live met bridge-code op schijf (systemd gebruikt dit ook vaak):
# QUANTBRIDGE_SRC_PATH=/root/dev/quant/quantbridge/src

QUANTBUILD_CONFIG=configs/strict_prod_v2.yaml
QUANTBRIDGE_CONFIG=configs/ctrader_icmarkets_demo.yaml
