# Copy to .env in this folder (or set these in the shell).
# Paths use forward slashes or escaped backslashes on Windows.
#
# Linux VPS: use absolute paths — see config.vps.example.env (copy to .env).

QUANTBUILD_ROOT=C:/Users/Gebruiker/quantbuildv1
QUANTBRIDGE_ROOT=C:/Users/Gebruiker/quantbridgev1
QUANTLOG_ROOT=C:/Users/Gebruiker/quantlogv1

# Optional: JSONL event store root (day folders underneath). Default: <QUANTBUILD_ROOT>/data/quantlog_events
# QUANTLOG_EVENTS_ROOT=

# Python executable (venv per repo is fine; this is only what the orchestrator invokes).
PYTHON=python

# Default configs (relative to each repo root)
QUANTBUILD_CONFIG=configs/strict_prod_v2.yaml
# IC Markets cTrader demo + OpenAPI (QuantBuild): configs/strict_prod_v2_ctrader_icmarkets.yaml
# QUANTBRIDGE_SRC_PATH=C:/Users/Gebruiker/quantbridgev1/src
QUANTBRIDGE_CONFIG=configs/ctrader_icmarkets_demo.yaml

# Optional: suite Telegram (monitoring.telegram in QuantBuild YAML):
#   python quantmetrics.py notify start build bridge log
#   python quantmetrics.py notify stop build bridge log --reason "shutdown"
