# Copy to .env (gitignored) or set the same keys in the real OS environment.
# Canonical reference: docs/CREDENTIALS_AND_ENVIRONMENT.md

# --- cTrader (QuantBridge) ---
CTRADER_ACCOUNT_ID=
CTRADER_ACCESS_TOKEN=
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=

# --- Oanda (alleen als je strict_prod_v2 / demo_*_prod_v2 gebruikt; niet voor cTrader) ---
OANDA_ACCOUNT_ID=
OANDA_TOKEN=

# --- Paths ---
QUANTBRIDGE_SRC_PATH=
QUANTLOG_REPO_PATH=
# QUANTLOG_ROOT=   # zelfde als QUANTLOG_REPO_PATH (alias)

# --- News / AI ---
NEWSAPI_KEY=
NEWSAPI_ENABLED=
NEWSAPI_CATEGORIES=
FINNHUB_API_KEY=
FINNHUB_ENABLED=
FINNHUB_CATEGORY=
