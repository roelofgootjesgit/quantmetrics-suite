OPENAI_MODEL=

# --- Telegram ---
TELEGRAM_ENABLED=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_SYSTEM_LABEL=
TELEGRAM_INSTANCE_LABEL=
TELEGRAM_REPORT_INTERVAL_SECONDS=

